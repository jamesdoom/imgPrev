# Vercel frontend build
VITE_API_BASE_URL=https://your-render-service.onrender.com

# Render web service
CORS_ORIGIN=https://your-vercel-project.vercel.app
HOST=0.0.0.0
# Render supplies PORT automatically. Use 4000 locally.
PORT=4000

# Neon Postgres
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
POSTGRES_SSL=true

# Cloudflare R2
R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=your-r2-bucket
R2_PREFIX=decal-sheet
R2_REGION=auto
# Optional only when stored files should have direct public URLs.
# R2_PUBLIC_BASE_URL=https://files.example.com

# SMTP print-order delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_TIMEOUT_MS=15000
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
PRINT_ORDER_EMAIL_FROM=orders@example.com
PRINT_ORDER_EMAIL_TO=orders@palmercodeworks.com,magicdecals@sunsignfactory.com
PRINT_ORDER_EMAIL_SUBJECT_PREFIX=New decal sheet order
# Optional override. When omitted, CORS_ORIGIN + /admin is used.
ADMIN_REVIEW_URL=https://your-vercel-project.vercel.app/admin

# Optional cleanup job
PROCESSED_MAX_AGE_MS=86400000
CLEANUP_CRON=0 * * * *
