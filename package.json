{
  "name": "image-preview-app",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "test": "vitest run",
    "test:baseline": "npm-run-all --sequential lint build test",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dev:backend": "ts-node --project tsconfig.node.json backend/server.ts",
    "cleanup": "node scripts/cleanupProcessed.js",
    "cleanup:watch": "node scripts/scheduledCleanup.js",
    "dev:all": "npm-run-all --parallel dev dev:backend"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "exifr": "^7.1.3",
    "express": "^5.1.0",
    "konva": "^9.3.20",
    "multer": "^1.4.5-lts.2",
    "node-cron": "^4.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.8",
    "react-easy-crop": "^5.5.0",
    "react-hot-toast": "^2.5.2",
    "react-hotkeys-hook": "^5.1.0",
    "react-konva": "^19.0.3",
    "sharp": "^0.34.1",
    "streamifier": "^0.1.1"
